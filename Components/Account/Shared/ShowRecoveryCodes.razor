<StatusMessage Message="@StatusMessage" />
<RadzenText TextStyle="TextStyle.H5">Recovery codes</RadzenText>
<RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" ShowIcon="true" class="rz-mb-3">
    <RadzenStack Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.Body1"><strong>Put these codes in a safe place.</strong></RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">If you lose your device and don't have the recovery codes you will lose access to your account.</RadzenText>
    </RadzenStack>
</RadzenAlert>
<RadzenStack Gap="0.5rem">
    @foreach (var recoveryCode in RecoveryCodes)
    {
        <RadzenCard Variant="Variant.Outlined" class="rz-p-2">
            <code class="recovery-code">@recoveryCode</code>
        </RadzenCard>
    }
</RadzenStack>

@code {
    [Parameter]
    public string[] RecoveryCodes { get; set; } = [];

    [Parameter]
    public string? StatusMessage { get; set; }
}
