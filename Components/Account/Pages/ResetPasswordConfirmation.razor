@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="rz-mt-6 rz-px-2">
    <RadzenColumn Size="12" SizeMD="10" SizeLG="6">
        <RadzenCard Variant="Variant.Filled" class="rz-p-4">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H5">Reset password confirmation</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1">
                    Your password has been reset. Please <RadzenLink Path="Account/Login" Text="click here to log in" />.
                </RadzenText>
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
