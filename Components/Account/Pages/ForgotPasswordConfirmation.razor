@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Forgot password confirmation</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="rz-mt-6 rz-px-2">
    <RadzenColumn Size="12" SizeMD="10" SizeLG="6">
        <RadzenCard Variant="Variant.Filled" class="rz-p-4">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H5">Forgot password confirmation</RadzenText>
                <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true" Text="Please check your email to reset your password." />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
