@page "/Account/AccessDenied"

<PageTitle>Access denied</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="rz-mt-6 rz-px-2">
    <RadzenColumn Size="12" SizeMD="10" SizeLG="6">
        <RadzenCard Variant="Variant.Filled" class="rz-p-4">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H5">Access denied</RadzenText>
                <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" Text="You do not have access to this resource." />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
