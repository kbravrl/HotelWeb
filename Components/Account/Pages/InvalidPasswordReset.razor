@page "/Account/InvalidPasswordReset"

<PageTitle>Invalid password reset</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" class="rz-mt-6 rz-px-2">
    <RadzenColumn Size="12" SizeMD="10" SizeLG="6">
        <RadzenCard Variant="Variant.Filled" class="rz-p-4">
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H5">Invalid password reset</RadzenText>
                <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" Text="The password reset link is invalid." />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>
