@page "/employees"

@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.Receptionist}")]
@inject IEmployeeService _employeeService
@inject NavigationManager _navigationManager
@inject IJSRuntime _jsRuntime
@inject DialogService _dialogService

<PageTitle>Employees</PageTitle>

<RadzenStack Gap="12px">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H3">Employees</RadzenText>

        <RadzenColumn Size="12">
            <RadzenButton Icon="add"
                          Text="New Employee"
                          ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => _navigationManager.NavigateTo("/employees/create"))" />
        </RadzenColumn>
    </RadzenStack>

    <RadzenDataGrid TItem="Employee"
                    Data="@Items"
                    AllowPaging="true"
                    PageSize="10"
                    AllowSorting="true"
                    AllowFiltering="true"
                    FilterMode="FilterMode.Simple"
                    Responsive="true"
                    EmptyText="No employees found.">
        <Columns>
            <RadzenDataGridColumn TItem="Employee"
                                  Property="Id"
                                  Title="ID"
                                  Width="80px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="FirstName"
                                  Title="First Name"
                                  Width="150px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="LastName"
                                  Title="Last Name"
                                  Width="150px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="Email"
                                  Title="Email"
                                  Width="200px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="Phone"
                                  Title="Phone"
                                  Width="150px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="Role"
                                  Title="Role"
                                  Width="150px" />

            <RadzenDataGridColumn TItem="Employee"
                                  Property="HireDate"
                                  Title="Hire Date"
                                  Width="130px">
                <Template Context="e">
                    @(e.HireDate?.ToString("dd/MM/yyyy") ?? "-")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Employee"
                                  Property="Salary"
                                  Title="Salary"
                                  Width="120px">
                <Template Context="e">
                    @(e.Salary.HasValue ? e.Salary.Value.ToString("C") : "-")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Employee"
                                  Property="IsActive"
                                  Title="Status"
                                  Width="100px">
                <Template Context="e">
                    <RadzenBadge Text="@(e.IsActive ? "Active" : "Inactive")"
                                 BadgeStyle="@(e.IsActive ? BadgeStyle.Success : BadgeStyle.Danger)" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Employee"
                                  Title="Tasks"
                                  Width="100px"
                                  Sortable="false"
                                  Filterable="false">
                <Template Context="e">
                    <RadzenBadge Text="@e.AssignedTasks.Count.ToString()"
                                 BadgeStyle="BadgeStyle.Info" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Employee"
                                  Property="CreatedAt"
                                  Title="Created"
                                  Width="150px">
                <Template Context="e">
                    @e.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Employee"
                                  Title="Actions"
                                  Width="220px"
                                  Sortable="false"
                                  Filterable="false">
                <Template Context="e">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" AlignItems="AlignItems.Center">
                        
                        <RadzenButton Icon="edit"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Click="@(() => _navigationManager.NavigateTo($"/employees/{e.Id}/edit"))"
                                      title="Edit" />

                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Click="@(() => Delete(e.Id))"
                                      title="Delete" />

                        @if (e.IsActive)
                        {
                            <RadzenButton Icon="block"
                                          ButtonStyle="ButtonStyle.Warning"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => ToggleStatus(e.Id, false))"
                                          title="Deactivate" />
                        }
                        else
                        {
                            <RadzenButton Icon="check_circle"
                                          ButtonStyle="ButtonStyle.Success"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => ToggleStatus(e.Id, true))"
                                          title="Activate" />
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    private List<Employee> Items { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Items = await _employeeService.GetAllEmployeesAsync();
    }

    private async Task Delete(int id)
    {
        var employee = await _employeeService.GetEmployeeAsync(id);
        if (employee == null) return;

        var confirmed = await _dialogService.Confirm(
            $"Are you sure you want to delete {employee.FirstName} {employee.LastName}?",
            "Delete Employee",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed == true)
        {
            try
            {
                await _employeeService.DeleteEmployeeAsync(id);
                await LoadAsync();
                await _jsRuntime.ToastrSuccess("Employee deleted successfully.");
            }
            catch (Exception ex)
            {
                await _jsRuntime.ToastrError(ex.Message);
            }
        }
    }

    private async Task ToggleStatus(int id, bool isActive)
    {
        try
        {
            var employee = await _employeeService.GetEmployeeAsync(id);
            if (employee != null)
            {
                employee.IsActive = isActive;
                await _employeeService.UpdateEmployeeAsync(employee);
                await LoadAsync();
                await _jsRuntime.ToastrSuccess($"Employee {(isActive ? "activated" : "deactivated")} successfully.");
            }
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }
}
