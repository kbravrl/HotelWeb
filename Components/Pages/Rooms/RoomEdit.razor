@page "/rooms/edit/{roomId:int}"
@rendermode InteractiveServer

@attribute [Authorize(Roles = AppRoles.Admin)]

@inject IRoomService _roomService
@inject IJSRuntime _jsRuntime
@inject NavigationManager _navigationManager

<PageTitle>Edit Room</PageTitle>

<RadzenCard class="rz-my-12 rz-mx-auto" Style="max-width: 600px;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 JustifyContent="JustifyContent.SpaceBetween"
                 AlignItems="AlignItems.Center"
                 class="rz-p-4">
        <RadzenStack Gap="0">
            <RadzenText TextStyle="TextStyle.Overline" class="rz-my-0">Room Management</RadzenText>
            <RadzenText TextStyle="TextStyle.H5" class="rz-my-0"><b>Edit Room</b></RadzenText>
        </RadzenStack>

        <RadzenButton Variant="Variant.Text"
                      class="rz-text-secondary-color"
                      Text="Back"
                      Icon="arrow_back"
                      Click="@(() => _navigationManager.NavigateTo("/rooms"))" />
    </RadzenStack>

    @if (loading)
    {
        <div class="rz-p-4">
            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
        </div>
    }
    else if (room == null)
    {
        <div class="rz-p-4">
            <RadzenAlert Severity="AlertSeverity.Warning">
                Room not found.
            </RadzenAlert>
        </div>
    }
    else
    {
        <RadzenStack Gap="16px" class="rz-p-4">
            <RadzenFormField Text="Room Number" Variant="Variant.Outlined">
                <RadzenTextBox @bind-Value="room.RoomNumber" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Room Type" Variant="Variant.Outlined">
                <RadzenDropDown @bind-Value="room.RoomType"
                                Data="@roomTypes"
                                Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Capacity" Variant="Variant.Outlined">
                <RadzenNumeric @bind-Value="room.Capacity"
                               Min="1"
                               Max="10"
                               ShowUpDown="true"
                               Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Base Price (₺)" Variant="Variant.Outlined">
                <RadzenNumeric @bind-Value="room.BasePrice"
                               Min="0"
                               TValue="decimal"
                               Format="n2"
                               ShowUpDown="false"
                               Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Status" Variant="Variant.Outlined">
                <RadzenDropDown @bind-Value="room.Status"
                                Data="@roomStatuses"
                                Style="width: 100%;" />
            </RadzenFormField>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.End"
                     Gap="8px"
                     class="rz-p-4">
            <RadzenButton Variant="Variant.Text"
                          class="rz-text-secondary-color"
                          Text="Cancel"
                          Disabled="@saving"
                          Click="@(() => _navigationManager.NavigateTo("/rooms"))" />

            <RadzenButton Text="@(saving ? "Saving..." : "Save Changes")"
                          ButtonStyle="ButtonStyle.Primary"
                          Disabled="@saving"
                          Click="@UpdateRoom" />
        </RadzenStack>
    }
</RadzenCard>

@code {
    [Parameter]
    public int RoomId { get; set; }

    private Room? room;
    private bool loading = true;
    private bool saving;

    private RoomType[] roomTypes = Enum.GetValues<RoomType>();
    private RoomStatus[] roomStatuses = Enum.GetValues<RoomStatus>();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoom();
    }

    private async Task LoadRoom()
    {
        loading = true;
        room = await _roomService.GetRoomAsync(RoomId);
        loading = false;
    }

    private async Task UpdateRoom()
    {
        if (room == null)
            return;

        if (string.IsNullOrWhiteSpace(room.RoomNumber))
        {
            await _jsRuntime.ToastrError("Room number is required.");
            return;
        }

        if (room.BasePrice <= 0)
        {
            await _jsRuntime.ToastrError("Base price must be greater than 0.");
            return;
        }

        saving = true;

        try
        {
            await _roomService.UpdateAsync(room);
            await _jsRuntime.ToastrSuccess($"Room {room.RoomNumber} updated successfully!");
            _navigationManager.NavigateTo("/rooms");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
        finally
        {
            saving = false;
        }
    }
}
