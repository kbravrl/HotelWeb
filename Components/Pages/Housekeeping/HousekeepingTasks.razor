@page "/housekeeping"

@rendermode InteractiveServer
@attribute [Authorize(Roles = AppRoles.Employee)]

@using HotelWeb.Components.Pages.Housekeeping

@inject IHousekeepingTaskService _housekeepingTaskService
@inject IEmployeeService _employeeService
@inject IRoomService _roomService
@inject DialogService _dialogService
@inject IJSRuntime _jsRuntime

<PageTitle>Housekeeping Tasks</PageTitle>

<RadzenStack Gap="12px">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H3">Housekeeping Tasks</RadzenText>
        <RadzenButton Text="Add Task" 
                      Icon="add" 
                      ButtonStyle="ButtonStyle.Primary" 
                      Click="@AddTask" />
    </RadzenStack>

    <RadzenDataGrid TItem="HousekeepingTask"
                    Data="@_tasks"
                    AllowPaging="true"
                    PageSize="10"
                    AllowSorting="true"
                    AllowFiltering="true"
                    FilterMode="FilterMode.Simple"
                    Responsive="true"
                    EmptyText="No housekeeping tasks found.">
        <Columns>
            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="Id"
                                  Title="ID"
                                  Width="80px" />

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="Room.RoomNumber"
                                  Title="Room Number"
                                  Width="130px">
                <Template Context="task">
                    @task.Room?.RoomNumber
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="Room.RoomType"
                                  Title="Room Type"
                                  Width="120px">
                <Template Context="task">
                    @if (task.Room != null)
                    {
                        <RadzenBadge Text="@task.Room.RoomType.ToString()"
                                     BadgeStyle="@BadgeStyles.ForRoomType(task.Room.RoomType)"
                                     Variant="Variant.Filled" />
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Title="Assigned To"
                                  Width="180px">
                <Template Context="task">
                    @if (task.AssignedToEmployee != null)
                    {
                        <span>@task.AssignedToEmployee.FirstName @task.AssignedToEmployee.LastName</span>
                    }
                    else
                    {
                        <span class="rz-text-secondary-color">Unassigned</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="Status"
                                  Title="Status"
                                  Width="130px">
                <Template Context="task">
                    <RadzenBadge Text="@task.Status.ToString()"
                                 BadgeStyle="@BadgeStyles.ForHousekeepingStatus(task.Status)"
                                 Variant="Variant.Filled" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="CreatedAt"
                                  Title="Created"
                                  Width="180px">
                <Template Context="task">
                    @task.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Property="CompletedAt"
                                  Title="Completed"
                                  Width="180px">
                <Template Context="task">
                    @(task.CompletedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="HousekeepingTask"
                                  Title="Actions"
                                  Width="300px"
                                  Sortable="false"
                                  Filterable="false">
                <Template Context="task">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" AlignItems="AlignItems.Center">
                        <RadzenButton Icon="edit"
                                      ButtonStyle="ButtonStyle.Light"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Click="@(() => EditTask(task))"
                                      title="Edit Task" />

                        @if (task.Status == HousekeepingTaskStatus.Pending)
                        {
                            <RadzenButton Icon="play_arrow"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => Start(task.Id))"
                                          title="Start Task" />
                        }
                        else if (task.Status == HousekeepingTaskStatus.InProgress)
                        {
                            <RadzenButton Icon="check_circle"
                                          ButtonStyle="ButtonStyle.Success"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => Done(task.Id))"
                                          title="Complete Task" />
                        }
                        else if (task.Status == HousekeepingTaskStatus.Done)
                        {
                            <RadzenIcon Icon="done_all" Style="color: var(--rz-success);" title="Completed" />
                        }

                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Click="@(() => DeleteTask(task))"
                                      title="Delete Task" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    private enum TaskFilterMode { Open, All, Completed }

    private List<HousekeepingTask> _tasks = new();
    private List<Employee> _employees = new();
    private TaskFilterMode _filterMode = TaskFilterMode.Open;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _employees = await _employeeService.GetAllEmployeesAsync();
    }

    private async Task LoadAsync()
    {
        var allTasks = await _housekeepingTaskService.GetAllTasksAsync();

        _tasks = _filterMode switch
        {
            TaskFilterMode.Open => allTasks.Where(t => t.Status != HousekeepingTaskStatus.Done).ToList(),
            TaskFilterMode.Completed => allTasks.Where(t => t.Status == HousekeepingTaskStatus.Done).ToList(),
            TaskFilterMode.All => allTasks,
            _ => allTasks
        };
    }

    private async Task SetFilter(TaskFilterMode mode)
    {
        _filterMode = mode;
        await LoadAsync();
    }

    private async Task Start(int id)
    {
        try
        {
            await _housekeepingTaskService.StartAsync(id);
            await LoadAsync();

            await _jsRuntime.ToastrSuccess($"Task #{id} started.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

    private async Task Done(int id)
    {
        try
        {
            await _housekeepingTaskService.CompleteAsync(id);
            await LoadAsync();

            await _jsRuntime.ToastrSuccess($"Task #{id} completed. Room set to Available.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

    private async Task AddTask()
    {
        var newTask = new HousekeepingTask();

        var result = await _dialogService.OpenAsync<TaskFormDialog>("Add Housekeeping Task",
            new Dictionary<string, object>
            {
                { "Task", newTask },
                { "IsEdit", false }
            },
            new DialogOptions { Width = "500px", Height = "auto" });

        if (result is HousekeepingTask task)
        {
            try
            {
                await _housekeepingTaskService.CreateTaskAsync(task);
                await LoadAsync();
                await _jsRuntime.ToastrSuccess("Task created successfully.");
            }
            catch (Exception ex)
            {
                await _jsRuntime.ToastrError(ex.Message);
            }
        }
    }

    private async Task EditTask(HousekeepingTask task)
    {
        var taskToEdit = new HousekeepingTask
        {
            Id = task.Id,
            RoomId = task.RoomId,
            AssignedToEmployeeId = task.AssignedToEmployeeId,
            Status = task.Status,
            CreatedAt = task.CreatedAt,
            CompletedAt = task.CompletedAt
        };

        var result = await _dialogService.OpenAsync<TaskFormDialog>("Edit Housekeeping Task",
            new Dictionary<string, object>
            {
                { "Task", taskToEdit },
                { "IsEdit", true }
            },
            new DialogOptions { Width = "500px", Height = "auto" });

        if (result is HousekeepingTask updatedTask)
        {
            try
            {
                await _housekeepingTaskService.UpdateTaskAsync(updatedTask);
                await LoadAsync();
                await _jsRuntime.ToastrSuccess("Task updated successfully.");
            }
            catch (Exception ex)
            {
                await _jsRuntime.ToastrError(ex.Message);
            }
        }
    }

    private async Task DeleteTask(HousekeepingTask task)
    {
        var confirmed = await _dialogService.Confirm(
            $"Are you sure you want to delete this task for Room {task.Room?.RoomNumber}?",
            "Delete Task",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed == true)
        {
            try
            {
                await _housekeepingTaskService.DeleteTaskAsync(task.Id);
                await LoadAsync();
                await _jsRuntime.ToastrSuccess("Task deleted successfully. Room set to Available.");
            }
            catch (Exception ex)
            {
                await _jsRuntime.ToastrError(ex.Message);
            }
        }
    }
}
