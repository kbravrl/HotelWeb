@page "/reservations"

@attribute [Authorize]

@inject AuthenticationStateProvider _authStateProvider
@inject IReservationService _reservationService
@inject ICustomerService _customerService
@inject NavigationManager _navigationManager
@inject IJSRuntime _jsRuntime

<PageTitle>Reservations</PageTitle>

<RadzenStack Gap="12px">
    <RadzenText TextStyle="TextStyle.H3">Reservations</RadzenText>

    <RadzenDataGrid TItem="Reservation"
                    Data="@Items"
                    AllowPaging="true"
                    PageSize="10"
                    AllowSorting="true"
                    AllowFiltering="true"
                    FilterMode="FilterMode.Simple"
                    Responsive="true"
                    EmptyText="No reservations found.">
        <Columns>
            <RadzenDataGridColumn TItem="Reservation"
                                  Property="Id"
                                  Title="ID"
                                  Width="80px" />

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="Room.RoomNumber"
                                  Title="Room"
                                  Width="100px">
                <Template Context="r">
                    @r.Room?.RoomNumber
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation"
                                  Title="Customer"
                                  Width="180px">
                <Template Context="r">
                    @if (r.Customer != null)
                    {
                        <span>@r.Customer.FirstName @r.Customer.LastName</span>
                    }
                    else
                    {
                        <span class="rz-text-secondary-color">-</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="CheckIn"
                                  Title="Check-In"
                                  Width="130px">
                <Template Context="r">
                    @r.CheckIn.ToString("dd/MM/yyyy")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="CheckOut"
                                  Title="Check-Out"
                                  Width="130px">
                <Template Context="r">
                    @r.CheckOut.ToString("dd/MM/yyyy")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="GuestCount"
                                  Title="Guests"
                                  Width="100px" />

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="TotalPrice"
                                  Title="Total"
                                  Width="120px">
                <Template Context="r">
                    @r.TotalPrice.ToString("C")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation" 
                                  Property="Status"
                                  Title="Status" 
                                  Width="120px">
                <Template Context="r">
                    <RadzenBadge Text="@r.Status.ToString()"
                                 BadgeStyle="@BadgeStyles.ForReservationStatus(r.Status)" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation"
                                  Property="CreatedAt"
                                  Title="Created"
                                  Width="150px">
                <Template Context="r">
                    @r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="Reservation" 
                                  Title="Actions" 
                                  Width="280px" 
                                  Sortable="false" 
                                  Filterable="false">
                <Template Context="r">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" AlignItems="AlignItems.Center">
                        <RadzenButton Icon="visibility"
                                      ButtonStyle="ButtonStyle.Info"
                                      Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Click="@(() => _navigationManager.NavigateTo($"/reservations/{r.Id}"))"
                                      title="View Details" />

                        @if (r.Status == ReservationStatus.Pending || r.Status == ReservationStatus.Confirmed)
                        {
                            <RadzenButton Icon="edit"
                                          ButtonStyle="ButtonStyle.Secondary"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => _navigationManager.NavigateTo($"/reservations/{r.Id}/edit"))"
                                          title="Edit" />
                        }

                        <AuthorizeView Roles="@AppRoles.Employee">
                            @if (r.Status == ReservationStatus.Pending)
                            {
                                <RadzenButton Icon="check_circle"
                                              ButtonStyle="ButtonStyle.Success"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => Confirm(r.Id))"
                                              title="Confirm" />

                                <RadzenButton Icon="cancel"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => Cancel(r.Id))"
                                              title="Cancel" />
                            }
                            else if (r.Status == ReservationStatus.Confirmed)
                            {
                                <RadzenButton Icon="login"
                                              ButtonStyle="ButtonStyle.Success"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => CheckIn(r.Id))"
                                              title="Check-In" />

                                <RadzenButton Icon="person_off"
                                              ButtonStyle="ButtonStyle.Secondary"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => NoShow(r.Id))"
                                              title="No Show" />

                                <RadzenButton Icon="cancel"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => Cancel(r.Id))"
                                              title="Cancel" />
                            }
                            else if (r.Status == ReservationStatus.CheckedIn)
                            {
                                <RadzenButton Icon="logout"
                                              ButtonStyle="ButtonStyle.Warning"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => CheckOut(r.Id))"
                                              title="Check-Out" />
                            }
                        </AuthorizeView>

                        <AuthorizeView Roles="@AppRoles.Customer">
                            @if (r.Status == ReservationStatus.Pending || r.Status == ReservationStatus.Confirmed)
                            {
                                <RadzenButton Icon="cancel"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              Click="@(() => Cancel(r.Id))"
                                              title="Cancel Reservation" />
                            }
                        </AuthorizeView>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    private IEnumerable<Reservation> Items { get; set; } = new List<Reservation>();
    private bool _isEmployee;
    private int? _customerIdInt;
    protected override async Task OnInitializedAsync()
    {
        var state = await _authStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        _isEmployee = user.IsInRole(AppRoles.Employee);

        if (!_isEmployee)
        {
            var applicationUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(applicationUserId))
            {
                var customer = await _customerService.GetCustomerByApplicationUserIdAsync(applicationUserId);

                if (customer != null)
                    _customerIdInt = customer.Id;
            }
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        Items = await _reservationService.GetVisibleAsync(_isEmployee, _customerIdInt);
    }

    private async Task Confirm(int id)
    {
        try
        {
            await _reservationService.ConfirmAsync(id);
            await LoadAsync();
            await _jsRuntime.ToastrSuccess($"Reservation #{id} confirmed.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

    private async Task Cancel(int id)
    {
        try
        {
            await _reservationService.CancelAsync(id);
            await LoadAsync();
            await _jsRuntime.ToastrSuccess($"Reservation #{id} cancelled.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

    private async Task NoShow(int id)
    {
        try
        {
            await _reservationService.MarkNoShowAsync(id);
            await LoadAsync();
            await _jsRuntime.ToastrSuccess($"Reservation #{id} marked as no-show.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }
    private async Task CheckIn(int id)
    {
        try
        {
            await _reservationService.CheckInAsync(id);
            await LoadAsync();
            await _jsRuntime.ToastrSuccess($"Guest checked-in successfully.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

    private async Task CheckOut(int id)
    {
        try
        {
            await _reservationService.CheckOutAsync(id);
            await LoadAsync();
            await _jsRuntime.ToastrSuccess($"Guest checked-out successfully.");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
    }

}