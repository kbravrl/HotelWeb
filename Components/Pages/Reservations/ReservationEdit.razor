@page "/reservations/{Id:int}/edit"

@attribute [Authorize]

@inject AuthenticationStateProvider _authStateProvider
@inject IReservationService _reservationService
@inject ICustomerService _customerService
@inject NavigationManager _navigationManager
@inject IJSRuntime _jsRuntime

<PageTitle>Edit Reservation</PageTitle>

@if (_loading)
{
    <RadzenStack Gap="1rem" class="rz-p-4 rz-my-12 rz-mx-auto" Style="max-width: 600px;">
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center">
            Loading reservation...
        </RadzenText>
    </RadzenStack>
}
else if (_reservation is null)
{
    <RadzenStack Gap="1rem" class="rz-p-4 rz-my-12 rz-mx-auto" Style="max-width: 600px;">
        <RadzenAlert Severity="AlertSeverity.Warning" Variant="Variant.Flat">
            Reservation not found.
        </RadzenAlert>

        <RadzenButton Text="Back to Reservations"
                      Icon="arrow_back"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => _navigationManager.NavigateTo("/reservations"))" />
    </RadzenStack>
}
else if (_reservation.Status != ReservationStatus.Pending && _reservation.Status != ReservationStatus.Confirmed)
{
    <RadzenStack Gap="1rem" class="rz-p-4 rz-my-12 rz-mx-auto" Style="max-width: 600px;">
        <RadzenAlert Severity="AlertSeverity.Info" Variant="Variant.Flat">
            Only Pending or Confirmed reservations can be edited.
        </RadzenAlert>

        <RadzenButton Text="Back to Details"
                      Icon="arrow_back"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => _navigationManager.NavigateTo($"/reservations/{Id}"))" />
    </RadzenStack>
}
else
{
    <RadzenCard class="rz-my-12 rz-mx-auto" Style="max-width: 600px;">
        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center"
                     class="rz-p-4">
            <RadzenStack Gap="0">
                <RadzenText TextStyle="TextStyle.Overline" class="rz-my-0">Reservation #@Id</RadzenText>
                <RadzenText TextStyle="TextStyle.H5" class="rz-my-0"><b>Edit Reservation</b></RadzenText>
            </RadzenStack>

            <RadzenButton Variant="Variant.Text"
                          class="rz-text-secondary-color"
                          Text="Back"
                          Icon="arrow_back"
                          Click="@(() => _navigationManager.NavigateTo($"/reservations"))" />
        </RadzenStack>

        <div class="rz-p-4">
            <RadzenAlert Severity="AlertSeverity.Info" Variant="Variant.Flat" class="rz-mb-4">
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Body2">
                        <b>Note:</b> You can only change the dates and guest count.
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">
                        Room: <b>@_reservation.Room?.RoomNumber</b> (cannot be changed)
                    </RadzenText>
                </RadzenStack>
            </RadzenAlert>

            @if (_reservation.Room != null)
            {
                <RoomSummaryCard Room="_reservation.Room" />
            }
        </div>

        <RadzenCard class="rz-background-color-primary-light rz-shadow-0 rz-border-radius-0 rz-p-8"
                    style="margin: 0 calc(-1 * var(--rz-card-padding));">
            <RadzenText TextStyle="TextStyle.H6" class="rz-color-on-primary-light">
                <strong>Reservation Details</strong>
            </RadzenText>

            <RadzenRow RowGap="0" class="rz-mt-2">
                <RadzenColumn SizeSM="6">
                    <RadzenText TextStyle="TextStyle.Overline"
                                class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">
                        Check-in
                    </RadzenText>

                    <RadzenDatePicker Style="width: 100%;"
                                      @bind-Value="_checkIn"
                                      DateFormat="dd/MM/yyyy" />
                </RadzenColumn>

                <RadzenColumn SizeSM="6">
                    <RadzenText TextStyle="TextStyle.Overline"
                                class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">
                        Check-out
                    </RadzenText>

                    <RadzenDatePicker Style="width: 100%;"
                                      @bind-Value="_checkOut"
                                      DateFormat="dd/MM/yyyy" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Overline"
                                class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">
                        Number of Guests
                    </RadzenText>

                    <RadzenNumeric Style="width: 100%;"
                                   @bind-Value="_guestCount"
                                   Min="1"
                                   Max="@(_reservation.Room?.Capacity ?? 10)"
                                   ShowUpDown="true" />

                    @if (_reservation.Room != null)
                    {
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-on-primary-light rz-mt-1">
                            Maximum capacity: @_reservation.Room.Capacity
                        </RadzenText>
                    }
                </RadzenColumn>
            </RadzenRow>

            @if (_checkIn.HasValue && _checkOut.HasValue && _reservation.Room != null)
            {
                var nights = (_checkOut.Value.Date - _checkIn.Value.Date).Days;
                var totalPrice = nights * _reservation.Room.BasePrice;

                <RadzenStack Gap="0.5rem" class="rz-mt-4 rz-p-3" Style="background-color: rgba(255,255,255,0.1); border-radius: 4px;">
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-on-primary-light">
                        <strong>Updated Pricing Summary</strong>
                    </RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenText TextStyle="TextStyle.Caption" class="rz-color-on-primary-light">
                            @nights night(s) × @_reservation.Room.BasePrice.ToString("C")
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light">
                            <strong>@totalPrice.ToString("C")</strong>
                        </RadzenText>
                    </RadzenStack>
                </RadzenStack>
            }
        </RadzenCard>

        <RadzenStack Orientation="Orientation.Horizontal"
                     JustifyContent="JustifyContent.End"
                     Gap="0"
                     class="rz-p-4">
            <RadzenButton Variant="Variant.Text"
                          class="rz-text-secondary-color"
                          Text="Cancel"
                          Disabled="@_saving"
                          Click="@(() => _navigationManager.NavigateTo($"/reservations/{Id}"))" />

            <RadzenButton Variant="Variant.Text"
                          Text="@(_saving ? "Saving..." : "Save Changes")"
                          Disabled="@_saving"
                          Click="@UpdateReservation" />
        </RadzenStack>
    </RadzenCard>
}

@code {
    [Parameter] public int Id { get; set; }

    private Reservation? _reservation;
    private DateTime? _checkIn;
    private DateTime? _checkOut;
    private int _guestCount;

    private bool _saving;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        try
        {
            _reservation = await _reservationService.GetByIdAsync(Id);

            if (_reservation is null)
                return;

            var state = await _authStateProvider.GetAuthenticationStateAsync();
            var user = state.User;
            var isReceptionistOrAdmin = user.IsInRole(AppRoles.Receptionist) || user.IsInRole(AppRoles.Admin);

            if (!isReceptionistOrAdmin)
            {
                var applicationUserId = user.FindFirstValue(ClaimTypes.NameIdentifier);

                if (!string.IsNullOrWhiteSpace(applicationUserId))
                {
                    var customer = await _customerService.GetByApplicationUserIdAsync(applicationUserId);

                    if (customer == null || _reservation.CustomerId != customer.Id)
                    {
                        _navigationManager.NavigateTo("/reservations");
                        _reservation = null;
                        return;
                    }
                }
            }

            _checkIn = _reservation.CheckIn.ToDateTime(TimeOnly.MinValue);
            _checkOut = _reservation.CheckOut.ToDateTime(TimeOnly.MinValue);
            _guestCount = _reservation.GuestCount;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task UpdateReservation()
    {
        if (_reservation is null)
            return;

        if (!_checkIn.HasValue || !_checkOut.HasValue)
        {
            await _jsRuntime.ToastrError("Please select check-in and check-out dates.");
            return;
        }

        if (_checkOut.Value.Date <= _checkIn.Value.Date)
        {
            await _jsRuntime.ToastrError("Check-out date must be after check-in date.");
            return;
        }

        if (_guestCount <= 0)
        {
            await _jsRuntime.ToastrError("Guest count must be at least 1.");
            return;
        }

        if (_reservation.Room != null && _guestCount > _reservation.Room.Capacity)
        {
            await _jsRuntime.ToastrError($"Guest count exceeds room capacity ({_reservation.Room.Capacity}).");
            return;
        }

        _saving = true;

        try
        {
            await _reservationService.UpdateAsync(
                reservationId: Id,
                checkIn: DateOnly.FromDateTime(_checkIn.Value),
                checkOut: DateOnly.FromDateTime(_checkOut.Value),
                guestCount: _guestCount
            );

            await _jsRuntime.ToastrSuccess("Reservation updated successfully!");
            _navigationManager.NavigateTo($"/reservations/{Id}");
        }
        catch (Exception ex)
        {
            await _jsRuntime.ToastrError(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }
}
